{
  "name": "itourisme-nomade-backend",
  "version": "1.0.0",
  "description": "Backend iTourisme Nomade - Node.js/Express/Prisma/PostgreSQL",
  "main": "dist/src/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/src/app.js",
    "start:prod": "npx prisma migrate deploy && (npx prisma db seed || true) && npm run start",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed": "node dist/prisma/seed.js",
    "db:reset": "prisma migrate reset --force",
    "db:setup": "prisma generate && prisma migrate deploy && npm run seed",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "itourisme",
    "backend",
    "cms",
    "nodejs",
    "express",
    "prisma"
  ],
  "author": "iTourisme Nomade Team",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0",
    "slugify": "^1.6.6",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  }
  
}