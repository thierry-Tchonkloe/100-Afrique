# .env.example
# ========================================
# CONFIGURATION iTourisme Nomade Backend
# ========================================

# Environnement (development, production, test)
NODE_ENV=development

# Port du serveur
PORT=5000

# ========================================
# BASE DE DONNÉES PostgreSQL
# ========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:root@localhost:5432/itourisme_nomade"
# DATABASE_URL="postgresql://itourisme_admin:M70Wh4foZKfNLaG5Hxc2N8wYg4sj01bX@dpg-d6m0pon5gffc73b52bt0-a/itourisme_nomade"

# ========================================
# AUTHENTIFICATION JWT
# ========================================
# Secret pour signer les tokens (générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=c4ea37560cee0b63cfbe84a9a3698b465fe93b3d3f323d9ca429c5a372af8a9f379fac8368b4aa2e4d03c0d0e4e567a28614069d87218c62236963e79db44292

# Durée de validité du token (ex: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# ========================================
# CLOUDINARY (Stockage Images)
# ========================================
# Obtenez vos credentials sur: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=dh0xwwyal
CLOUDINARY_API_KEY=834336362883721
CLOUDINARY_API_SECRET=wBBbojjdZiTn5MKUv2NkuJla7zU

# Dossier de stockage Cloudinary (optionnel)
CLOUDINARY_FOLDER=itourisme-nomade-cloud

# ========================================
# SÉCURITÉ
# ========================================
# Origines autorisées pour CORS (séparées par des virgules)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Nombre de rounds pour bcrypt (10-12 recommandé)
BCRYPT_ROUNDS=10

# ========================================
# RATE LIMITING
# ========================================
# Nombre maximum de requêtes par fenêtre de temps
RATE_LIMIT_MAX=100

# Fenêtre de temps en minutes
RATE_LIMIT_WINDOW_MS=15

# ========================================
# CACHE
# ========================================
# Durée du cache en secondes (pour les catégories, etc.)
CACHE_TTL=3600

# ========================================
# PAGINATION
# ========================================
# Nombre d'articles par page par défaut
DEFAULT_PAGE_SIZE=10

# Nombre maximum d'articles par page
MAX_PAGE_SIZE=50